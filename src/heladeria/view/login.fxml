<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>

<VBox alignment="CENTER" spacing="15.0" styleClass="panel-fondo" stylesheets="@estilo.css" xmlns="http://javafx.com/javafx/8" xmlns:fx="http://javafx.com/fxml/1" fx:controller="heladeria.view.LoginController">
    <padding>
        <Insets bottom="30.0" left="40.0" right="40.0" top="30.0" />
    </padding>

    <HBox prefHeight="20.0" styleClass="barra-cuadros" />

    <Label styleClass="titulo-azul" text="Iniciar Sesión">
        <font><Font name="System Bold" size="28.0" /></font>
    </Label>
    <Label text="Ingresa tus credenciales para continuar." textFill="#1a56db" />

    <VBox spacing="5.0" style="-fx-padding: 10 0 0 0;">
        <Label styleClass="etiqueta-negra" text="ID de Pingüino/Usuario:" />
        <TextField fx:id="txtUsuario" styleClass="input-pizzatron" />
    </VBox>

    <VBox spacing="5.0">
        <Label styleClass="etiqueta-negra" text="Contraseña Secreta:" />
        <PasswordField fx:id="txtPass" styleClass="input-pizzatron" />
    </VBox>

    <HBox alignment="CENTER" spacing="20.0" style="-fx-padding: 15 0 15 0;">
        <RadioButton fx:id="rbEmpleado" selected="true" styleClass="radio-pizzatron" text="Empleado">
            <toggleGroup><ToggleGroup fx:id="grupoRol" /></toggleGroup>
        </RadioButton>
        <RadioButton fx:id="rbCliente" styleClass="radio-pizzatron" text="Cliente" toggleGroup="$grupoRol" />
    </HBox>

    <Button fx:id="btnIngresar" mnemonicParsing="false" onAction="#ingresarAlSistema" styleClass="btn-verde-pizzatron" text="INGRESAR AL SISTEMA" />
</VBox>